NODE_ENV=development
PORT=3000

# --- DESENVOLVIMENTO LOCAL ---
# PostgreSQL local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=claudezap
DB_USER=postgres
DB_PASS=postgres

# Redis local
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- PRODUÇÃO (substitui as vars acima) ---
# Neon PostgreSQL (cole a connection string do painel do Neon)
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/claudezap?sslmode=require

# Upstash Redis (cole a connection string do painel do Upstash)
# REDIS_URL=rediss://default:password@hostname:6380

# JWT
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio
JWT_EXPIRES_IN=7d

# WhatsApp
WA_SESSION_DIR=./wa_sessions

# Fila
MSG_DELAY_MS=3000
MSG_RATE_LIMIT_PER_MIN=20

# CORS — URL do frontend (Vercel em prod, localhost em dev)
CORS_ORIGIN=http://localhost:5173

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Clica Aí <noreply@seudominio.com.br>
APP_URL=https://app.clicaai.com.br

# Notificação de novo cadastro (email do admin)
ADMIN_NOTIFY_EMAIL=admin@seudominio.com.br
