NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=claudezap
DB_USER=postgres
DB_PASS=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# WhatsApp session storage path (relative to project root)
WA_SESSION_DIR=./wa_sessions

# Queue settings
MSG_DELAY_MS=3000
MSG_RATE_LIMIT_PER_MIN=20
